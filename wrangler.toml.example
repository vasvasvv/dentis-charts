name = "dentis-cards-api"
main = "src/worker.ts"
compatibility_date = "2024-01-01"
compatibility_flags = ["nodejs_compat"]
account_id = "YOUR_CLOUDFLARE_ACCOUNT_ID"
workers_dev = true

[build]
command = "echo 'No build needed'"

[build.upload]
format = "modules"
main = "./src/worker.ts"

[[d1_databases]]
binding = "DB"
database_name = "dentis-charts"
database_id = "YOUR_D1_DATABASE_ID"

# JWT_SECRET має бути встановлений через wrangler secret put JWT_SECRET
# Для локальної розробки використовуйте .dev.vars файл
