build/
target/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
.ENV
.ENV.*
.python-version
.pytest_cache/
.mypy_cache/
.coverage
coverage/

# Logs
*.log

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Thumbs.db:encryptable

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Environment variables
.env
.env.local
.env.*
!.env.example
.dev.vars.example

# Testing
coverage/
htmlcov/
.nyc_output/
istanbul/
```

